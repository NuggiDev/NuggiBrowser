<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="nuggiUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:nuggiUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    >

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="T" Modifiers="Control" Invoked="NewTab_Shortcut"/>
        <KeyboardAccelerator Key="W" Modifiers="Control" Invoked="CloseTab_Shortcut"/>
        <KeyboardAccelerator Key="L" Modifiers="Control" Invoked="FocusUrl_Shortcut"/>
        <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="Refresh_Shortcut"/>
    </Page.KeyboardAccelerators>

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Page.Resources>
        <Style x:Key="NavIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <SplitView x:Name="SidebarSplitView"
               DisplayMode="Inline"
               IsPaneOpen="False"
               OpenPaneLength="220"
               CompactPaneLength="0"
               PaneBackground="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        
        <SplitView.Pane>
            <Grid x:Name="SidebarRoot" 
                  PointerExited="Sidebar_PointerExited"
                  Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SIDEBAR TOP (drag area) -->
                <Border Grid.Row="0"
                        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                        Padding="16,0,12,0">
                    <TextBlock Text="NuggiBrowser"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Opacity="0.3"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- SIDEBAR CONTENT -->
                <Grid Grid.Row="1"
                      Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                      Padding="8,4,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Pinned tabs row -->
                    <ItemsControl Grid.Row="0"
                                  ItemsSource="{x:Bind PinnedTabs}"
                                  Margin="8,8,8,12">
                        <ItemsControl.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition/>
                                <EntranceThemeTransition IsStaggeringEnabled="True"/>
                            </TransitionCollection>
                        </ItemsControl.ItemContainerTransitions>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:BrowserTab">
                                <Button Width="32" Height="32" Padding="0" CornerRadius="8"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}" BorderThickness="0"
                                        Click="PinnedTab_Click" Tag="{x:Bind}"
                                        ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Unpin Tab" Click="UnpinTab_Click" Tag="{x:Bind}"/>
                                            <MenuFlyoutItem Text="Close Tab" Click="CloseTab_Click" Tag="{x:Bind}"/>
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{x:Bind FallbackVisibility, Mode=OneWay}"/>
                                        <Image Source="{x:Bind Favicon, Mode=OneWay}"
                                               Visibility="{x:Bind FaviconVisibility, Mode=OneWay}"
                                               Width="16" Height="16"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Space name -->
                    <TextBlock Grid.Row="1"
                               Text="My Space"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Opacity="0.35"
                               Margin="12,0,8,8"
                               CharacterSpacing="50"/>

                    <!-- Tab list -->
                    <ListView Grid.Row="2"
                              x:Name="TabsListView"
                              SelectionMode="Single"
                              SelectionChanged="TabsListView_SelectionChanged"
                              Padding="0">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition/>
                                <ReorderThemeTransition/>
                                <EntranceThemeTransition IsStaggeringEnabled="True"/>
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="CornerRadius" Value="8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:BrowserTab">
                                <Grid>
                                    <Grid.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Pin Tab" Click="PinTab_Click" Tag="{x:Bind}"/>
                                            <MenuFlyoutItem Text="Close Tab" Click="CloseTab_Click" Tag="{x:Bind}"/>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="16" Height="16" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE774;"
                                                  FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{x:Bind FallbackVisibility, Mode=OneWay}"/>
                                        <Image Source="{x:Bind Favicon, Mode=OneWay}" 
                                               Visibility="{x:Bind FaviconVisibility, Mode=OneWay}"
                                               Width="16" Height="16"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Title, Mode=OneWay}"
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="2"
                                            Content="&#xE711;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="9"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Width="22"
                                            Height="22"
                                            Padding="0"
                                            Click="CloseTab_Click"
                                            Tag="{x:Bind}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Separator -->
                    <Rectangle Grid.Row="3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="8,0"/>

                    <!-- New Tab button -->
                    <Button Grid.Row="4"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="10,8"
                            Margin="0,4,0,0"
                            CornerRadius="8"
                            Click="NewTab_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Text="New Tab" FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- NAV BAR -->
                <Grid Grid.Row="0"
                      x:Name="TopNavGrid"
                      Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                      PointerEntered="Content_PointerEntered">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="148"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back/Forward/Refresh/Settings -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="1"
                                Margin="8,0,4,0">
                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Click="Back_Click"
                                ToolTipService.ToolTip="Back">
                            <FontIcon Glyph="&#xE76B;" FontSize="11"/>
                        </Button>
                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Click="Forward_Click"
                                ToolTipService.ToolTip="Forward">
                            <FontIcon Glyph="&#xE76C;" FontSize="11"/>
                        </Button>
                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Click="Refresh_Click"
                                ToolTipService.ToolTip="Refresh">
                            <FontIcon Glyph="&#xE72C;" FontSize="11"/>
                        </Button>
                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Click="Settings_Click"
                                ToolTipService.ToolTip="Settings">
                            <FontIcon Glyph="&#xE713;" FontSize="11"/>
                        </Button>
                    </StackPanel>

                    <!-- URL Bar (clean rounded rect, not a pill) -->
                    <Border Grid.Column="1"
                            CornerRadius="8"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            Margin="4,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <FontIcon Grid.Column="0" 
                                      Glyph="&#xE72E;" 
                                      FontSize="12" 
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" 
                                      Margin="12,0,0,0" 
                                      VerticalAlignment="Center"/>
                                      
                            <TextBox Grid.Column="1"
                                     x:Name="UrlTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                     PlaceholderText="Search or enter URL"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Stretch"
                                     Padding="8,5,12,5"
                                     KeyDown="UrlTextBox_KeyDown"
                                     GotFocus="UrlTextBox_GotFocus"
                                     FontSize="13"
                                     SelectionHighlightColor="#5064C8"/>
                        </Grid>
                    </Border>

                    <!-- Loading Progress Bar -->
                    <ProgressBar x:Name="MainProgressBar" 
                                 Grid.Column="0" Grid.ColumnSpan="3" 
                                 VerticalAlignment="Bottom" 
                                 IsIndeterminate="True" 
                                 Visibility="Collapsed" 
                                 Height="2" 
                                 Margin="0,0,0,0"
                                 Foreground="#5064C8"/>

                    <!-- Spacer for native window controls -->
                    <Grid Grid.Column="2"/>
                </Grid>

                <!-- WEBVIEW CONTAINER -->
                <Grid Grid.Row="1"
                      x:Name="WebViewContainer"
                      Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"/>

                <!-- SIDEBAR DISMISS OVERLAY -->
                <Grid Grid.Row="1"
                      x:Name="SidebarDismissOverlay"
                      Background="Transparent"
                      Visibility="Collapsed"
                      PointerEntered="Content_PointerEntered"/>

                <!-- Hover Trigger Area (Invisible) -->
                <Rectangle Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Left" Width="12" Fill="Transparent" PointerEntered="HoverTrigger_PointerEntered"/>
            </Grid>
        </SplitView.Content>
    </SplitView>
</Page>


