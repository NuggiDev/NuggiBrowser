<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="nuggiUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:nuggiUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    RequestedTheme="Dark">

    <Page.Resources>
        <Style x:Key="NavIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SIDEBAR TOP (drag area) -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="#1A1A1A"
                Padding="16,0,12,0">
            <TextBlock Text="NuggiBrowser"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="#FFFFFF"
                       Opacity="0.3"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- NAV BAR -->
        <Grid Grid.Column="1" Grid.Row="0"
              x:Name="TopNavGrid"
              Background="#1A1A1A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="148"/>
            </Grid.ColumnDefinitions>

            <!-- Back/Forward/Refresh -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="1"
                        Margin="8,0,4,0">
                <Button Style="{StaticResource NavIconButtonStyle}"
                        Click="Back_Click"
                        ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE76B;" FontSize="11"/>
                </Button>
                <Button Style="{StaticResource NavIconButtonStyle}"
                        Click="Forward_Click"
                        ToolTipService.ToolTip="Forward">
                    <FontIcon Glyph="&#xE76C;" FontSize="11"/>
                </Button>
                <Button Style="{StaticResource NavIconButtonStyle}"
                        Click="Refresh_Click"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="11"/>
                </Button>
            </StackPanel>

            <!-- URL Bar (clean rounded rect, not a pill) -->
            <Border Grid.Column="1"
                    CornerRadius="8"
                    Background="#2C2C2C"
                    Margin="4,9">
                <TextBox x:Name="UrlTextBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E0E0E0"
                         PlaceholderText="Search or enter URL"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Stretch"
                         Padding="12,5"
                         KeyDown="UrlTextBox_KeyDown"
                         FontSize="13"
                         SelectionHighlightColor="#5064C8"/>
            </Border>

            <!-- Spacer for native window controls -->
            <Grid Grid.Column="2"/>
        </Grid>

        <!-- SIDEBAR CONTENT -->
        <Grid Grid.Column="0" Grid.Row="1"
              Background="#1A1A1A"
              Padding="8,4,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Pinned tabs row -->
            <StackPanel Grid.Row="0"
                        x:Name="PinnedTabsPanel"
                        Orientation="Horizontal"
                        Margin="8,8,8,12"
                        Spacing="6"/>

            <!-- Space name -->
            <TextBlock Grid.Row="1"
                       Text="My Space"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"
                       Opacity="0.35"
                       Margin="12,0,8,8"
                       CharacterSpacing="50"/>

            <!-- Tab list -->
            <ListView Grid.Row="2"
                      x:Name="TabsListView"
                      SelectionMode="Single"
                      SelectionChanged="TabsListView_SelectionChanged"
                      Padding="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Margin" Value="0,1"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:BrowserTab">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE774;"
                                      FontSize="12"
                                      VerticalAlignment="Center"
                                      Foreground="#AAAAAA"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind Title, Mode=OneWay}"
                                       FontSize="13"
                                       Foreground="#E0E0E0"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="2"
                                    Content="&#xE711;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="9"
                                    Foreground="#888888"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Width="22"
                                    Height="22"
                                    Padding="0"
                                    Click="CloseTab_Click"
                                    Tag="{x:Bind}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Separator -->
            <Rectangle Grid.Row="3" Fill="#303030" Margin="8,0"/>

            <!-- New Tab button -->
            <Button Grid.Row="4"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10,8"
                    Margin="0,4,0,0"
                    CornerRadius="8"
                    Click="NewTab_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="#888888"/>
                    <TextBlock Text="New Tab" FontSize="13" Foreground="#888888"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- WEBVIEW CONTAINER -->
        <Grid Grid.Column="1" Grid.Row="1"
              x:Name="WebViewContainer"
              Background="#1A1A1A"/>
    </Grid>
</Page>
